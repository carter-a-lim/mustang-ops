{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MustangContext",
  "type": "object",
  "required": ["updated_at", "deadlines", "events", "priorities", "experiments", "outreach_queue", "kpis"],
  "properties": {
    "updated_at": {"type": "string", "format": "date-time"},
    "deadlines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "course", "due_at", "source"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "course": {"type": "string"},
          "due_at": {"type": "string", "format": "date-time"},
          "source": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "events": {"type": "array", "items": {"type": "object"}},
    "priorities": {"type": "array", "items": {"type": "string"}},
    "experiments": {"type": "array", "items": {"type": "object"}},
    "outreach_queue": {"type": "array", "items": {"type": "object"}},
    "kpis": {
      "type": "object",
      "properties": {
        "downloads_7d": {"type": "number"},
        "new_listings_7d": {"type": "number"},
        "activation_rate": {"type": "number"},
        "weekly_outreach_touches": {"type": "number"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
