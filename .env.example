# Path requested for single source of truth
MUSTANG_CONTEXT_PATH=/home/ubuntu/mustang-ops/data/mustang_context.json

# OpenClaw Gateway
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=
OPENCLAW_MODEL=openclaw:main

# Optional local cost estimation (USD per 1M tokens)
MUSTANG_COST_INPUT_PER_1M=0
MUSTANG_COST_OUTPUT_PER_1M=0

# App bind
HOST=127.0.0.1
PORT=8080
